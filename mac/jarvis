#!/usr/bin/env bash
# Convenience launcher for the Jarvis Mac voice client.
# Creates a local virtualenv on first run, installs deps, then starts Jarvis.
# Any arguments are passed straight through, e.g. `./jarvis --auto`.
set -euo pipefail

cd "$(dirname "$0")"

VENV=".venv"
# The stamp is written only after a *complete* install, so a first run that was
# interrupted mid-download doesn't leave a broken venv that never gets repaired.
STAMP="$VENV/.deps-ok"
if [[ ! -f "$STAMP" ]]; then
  echo "Setting up Jarvis (one-time)…"
  python3 -m venv "$VENV"
  # shellcheck disable=SC1091
  source "$VENV/bin/activate"
  pip install --quiet --upgrade pip
  pip install --quiet -r requirements.txt
  touch "$STAMP"
else
  # shellcheck disable=SC1091
  source "$VENV/bin/activate"
fi

exec python3 jarvis_mac.py "$@"
